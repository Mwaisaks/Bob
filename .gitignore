# Environment & secrets — NEVER commit
.env
.env.*

# Python virtual environments
.venv/
bob-venv/
env/

# Python cache files
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Build / packaging artifacts
dist/
build/
*.egg-info/
*.egg

# Real user data — the whole point of this gitignore
data/real/
*.sqlite
MPESA_Statement*
*.pdf

# Generated data files — rebuild with ingest.py and knowledge_lookup.py --build
data/bob.db
data/knowledge_embeddings.pkl
data/cached_rates.json

# Ollama / model weights — huge files, never commit
*.gguf
*.bin
*.safetensors
models/

# IDE / OS noise
.vscode/
.idea/
.DS_Store
*.swp

# Test cache
.pytest_cache/
.coverage
htmlcov/
